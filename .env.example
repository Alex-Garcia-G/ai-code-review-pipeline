ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Optional: GitHub personal access token
# Without this, GitHub API is limited to 60 requests/hour (usually enough for demos)
# With this, limit raises to 5000 requests/hour
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# PostgreSQL connection string (required for review history)
# Railway provides this automatically when you add a PostgreSQL database to your project
# For local development, add your own PostgreSQL connection string
DATABASE_URL=
